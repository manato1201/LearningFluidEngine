# ============================================================
#  LearningFluidEngine — .gitignore
# ============================================================

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------
# Neural Fluid — 学習データ・モデル重み
# （再生成可能、大容量）
# ----------------------------------------------------------

# データセット（numpy配列、数十〜百MB）
**/dataset/
**/dataset_v2/
**/dataset_*/
**/*.npy
**/*.npz

# モデル重みチェックポイント（再訓練可能）
**/checkpoints/
**/checkpoints_v2/
**/checkpoints_v3/
**/checkpoints_*/
**/*.pt
**/*.pth

# ----------------------------------------------------------
# Blender — レンダリング出力
# ----------------------------------------------------------
**/render/
**/*.blend1

# ----------------------------------------------------------
# Three.js Viewer — 生成済みシミュレーションデータ
# （各スクリプトで再生成可能）
# ----------------------------------------------------------
**/viewer/data/

# ----------------------------------------------------------
# fluid-engine-dev SPH シミュレーション出力
# （sph_sim.exe で再生成可能）
# ----------------------------------------------------------
**/sph_output/
**/*.xyz

# ----------------------------------------------------------
# WebAssembly — コンパイル済みバイナリ
# （sph_wasm.cpp から emcc で再コンパイル可能）
# ----------------------------------------------------------
**/sph.wasm
**/sph.js

# ----------------------------------------------------------
# fluid-engine-dev SDK 本体（公開不可）
# ----------------------------------------------------------
Learners/
**/Learners/

# ----------------------------------------------------------
# OS / エディタ
# ----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ----------------------------------------------------------
# 一時ファイル・ログ
# ----------------------------------------------------------
*.tmp
*.log
*.bak
